<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- CONTENIDO PRINCIPAL SCROLLEABLE -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="96dp">
            <!-- paddingBottom para que el botón fijo no tape el último card -->

            <Space
                android:layout_width="match_parent"
                android:layout_height="50dp" />

            <!--Titulo de la APP-->
            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Atrapa al \n impostor"
                android:textColor="#333"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- CardView de Editar Jugadores -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewModoJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:radius="8dp">

                <!-- Usamos SOLO un RelativeLayout como root interno -->
                <RelativeLayout
                    android:id="@+id/relativeLayoutJugadores"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Título arriba, ocupando todo el ancho menos la flecha -->
                    <TextView
                        android:id="@+id/textTituloJugadores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:layout_toStartOf="@id/imageViewArrow"
                        android:layout_alignParentStart="true"
                        android:text="Editar Jugadores"
                        android:textColor="@color/tituloYFlecha"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Flecha a la derecha, centrada verticalmente en TODO el CardView -->
                    <ImageView
                        android:id="@+id/imageViewArrow"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/chevron_right_24"
                        app:tint="@color/tituloYFlecha" />

                    <!-- Lista de jugadores, debajo del título y a la izquierda de la flecha -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/playersRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textTituloJugadores"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:layout_toStartOf="@id/imageViewArrow"
                        android:layout_toLeftOf="@id/imageViewArrow"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:padding="0dp" />

                </RelativeLayout>
            </androidx.cardview.widget.CardView>


            <!-- CardView de Editar Categorías / Palabras -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:radius="8dp">

                <!-- RelativeLayout raíz interno -->
                <RelativeLayout
                    android:id="@+id/relativeLayoutCategorias"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Flecha a la derecha, centrada verticalmente en TODO el CardView -->
                    <ImageView
                        android:id="@+id/imageViewArrowCategorias"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/chevron_right_24"
                        app:tint="@color/tituloYFlecha" />

                    <!-- Título arriba, ocupando todo el ancho menos la flecha -->
                    <TextView
                        android:id="@+id/textTituloCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/imageViewArrowCategorias"
                        android:text="Categorías y palabras"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Resumen debajo del título, también hasta la flecha -->
                    <TextView
                        android:id="@+id/textResumenCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textTituloCategorias"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/imageViewArrowCategorias"
                        android:text="3 categorías disponibles"
                        android:textSize="14sp" />

                    <!-- Lista de categorías, debajo del resumen y a la izquierda de la flecha -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/categoriesRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textResumenCategorias"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:layout_toStartOf="@id/imageViewArrowCategorias"
                        android:layout_toLeftOf="@id/imageViewArrowCategorias"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingTop="8dp" />

                </RelativeLayout>
            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </ScrollView>

    <!-- BOTÓN FIJO ABAJO -->
    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="EMPEZAR PARTIDA" />

    <!-- OVERLAY OSCURO POR ENCIMA DE TODO -->
    <View
        android:id="@+id/darkOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone" />

</FrameLayout>
