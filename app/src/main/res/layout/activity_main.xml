<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.MainActivity">

    <!-- CONTENIDO PRINCIPAL SCROLLEABLE -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="96dp">
            <!-- paddingBottom para que el botón fijo no tape el último card -->

            <Space
                android:layout_width="match_parent"
                android:layout_height="50dp" />

            <!--Titulo de la APP-->
            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Atrapa al \n impostor"
                android:textColor="#333"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- CardView de Editar Jugadores -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewModoJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false">

                <RelativeLayout
                    android:id="@+id/relativeLayoutJugadores"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textTituloJugadores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginBottom="12dp"
                        android:layout_toStartOf="@id/imageViewArrow"
                        android:text="Editar Jugadores"
                        android:textColor="@color/tituloYFlecha"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/imageViewArrow"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/chevron_right_24"
                        app:tint="@color/tituloYFlecha" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/playersRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textTituloJugadores"
                        android:layout_toStartOf="@id/imageViewArrow"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:padding="0dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- CardView de Editar Categorías / Palabras -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false">

                <RelativeLayout
                    android:id="@+id/relativeLayoutCategorias"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imageViewArrowCategorias"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/chevron_right_24"
                        app:tint="@color/tituloYFlecha" />

                    <TextView
                        android:id="@+id/textTituloCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:layout_toStartOf="@id/imageViewArrowCategorias"
                        android:text="Categorías y palabras"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textResumenCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textTituloCategorias"
                        android:layout_toStartOf="@id/imageViewArrowCategorias"
                        android:text="3 categorías disponibles"
                        android:textSize="14sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/categoriesRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textResumenCategorias"
                        android:layout_toStartOf="@id/imageViewArrowCategorias"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingTop="8dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- CardView de Activar pista -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewPistaImpostor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtOpcionTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pista del impostor"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchPista"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />

                    <TextView
                        android:id="@+id/txtOpcionDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txtOpcionTitulo"
                        android:layout_marginTop="6dp"
                        android:layout_toStartOf="@id/switchModoLoco"
                        android:text="Activa una pista para ayudar al impostor a disimular"
                        android:textSize="13sp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- CardView de Modo loco (Todos son impostores) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewModoLoco"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtOpcionTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Todos impostores"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchModoLoco"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="false" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Activa un modo en el cual todos pueden ser impostores"
                        android:textSize="13sp"
                        android:layout_below="@+id/txtOpcionTitulo"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTÓN FIJO ABAJO -->
    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="EMPEZAR PARTIDA" />

    <!-- OVERLAY OSCURO POR ENCIMA DE TODO -->
    <View
        android:id="@+id/darkOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone" />

</FrameLayout>
