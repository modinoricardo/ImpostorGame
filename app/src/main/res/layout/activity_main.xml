<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- CONTENIDO PRINCIPAL SCROLLEABLE -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="96dp">
            <!-- paddingBottom para que el botón fijo no tape el último card -->

            <Space
                android:layout_width="match_parent"
                android:layout_height="50dp" />

            <!--Titulo de la APP-->
            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Atrapa al \n impostor"
                android:textColor="#333"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- CardView de Editar Jugadores -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewModoJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:radius="8dp">

                <LinearLayout
                    android:id="@+id/layoutModoJuego"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Editar Jugadores"
                        android:textColor="@color/tituloYFlecha"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:id="@+id/relativeLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/imageViewArrow"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/chevron_right_24"
                            app:tint="@color/tituloYFlecha" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/playersRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentLeft="true"
                            android:overScrollMode="never"
                            android:nestedScrollingEnabled="false"
                            android:layout_toStartOf="@id/imageViewArrow"
                            android:layout_toLeftOf="@id/imageViewArrow"
                            android:padding="0dp" />

                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CardView de Editar Categorías / Palabras -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:radius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Categorías y palabras"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textResumenCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3 categorías disponibles"
                        android:textSize="14sp" />

                    <RelativeLayout
                        android:id="@+id/relativeLayoutCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/imageViewArrowCategorias"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/chevron_right_24"
                            app:tint="@color/tituloYFlecha" />

                        <!-- lista de categorías dentro del card, altura fija -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/categoriesRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:overScrollMode="never"
                            android:nestedScrollingEnabled="false"
                            android:paddingTop="8dp" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTÓN FIJO ABAJO -->
    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="EMPEZAR PARTIDA" />

    <!-- OVERLAY OSCURO POR ENCIMA DE TODO -->
    <View
        android:id="@+id/darkOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone" />

</FrameLayout>
