<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dlgRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingLeft="36dp"
    android:paddingTop="56dp"
    android:paddingRight="36dp"
    android:paddingBottom="56dp">

    <TextView
        android:id="@+id/dlgIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="22dp"
        android:textSize="72sp" />

    <ImageView
        android:id="@+id/dlgIconImage"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="22dp"
        android:contentDescription="@null"
        android:visibility="gone" />

    <TextView
        android:id="@+id/dlgTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:fontFamily="sans-serif-medium"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/dlgMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:textAlignment="center"
        android:textColor="#C7C8D9"
        android:textSize="16sp" />

    <!-- Opción B: Cancelar arriba (ghost), acción principal abajo (neon) -->
    <Button
        android:id="@+id/dlgBtnNegative"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/btn_ghost"
        android:textAllCaps="false"
        android:textColor="#BFC4FF"
        android:textSize="14sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/dlgBtnPositive"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
