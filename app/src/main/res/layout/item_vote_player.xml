<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp">

    <FrameLayout
        android:layout_width="90dp"
        android:layout_height="90dp">

        <ImageView
            android:id="@+id/imgPlayerAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/civil1"
            android:background="@drawable/bg_card_main"
            android:clipToOutline="true" />

        <!-- Overlay seleccionado -->
        <View
            android:id="@+id/overlaySelected"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#8000E5FF"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txtCheck"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="✓"
            android:textSize="36sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:id="@+id/txtPlayerNameVote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Jugador"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>