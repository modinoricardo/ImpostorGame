<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Degradado azul oscuro tipo botón -->
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#152338"
        android:centerColor="#1E2F4A"
        android:endColor="#26385C" />

    <!-- Esquinas redondeadas -->
    <corners android:radius="22dp" />

    <!-- Borde morado suave -->
    <stroke
        android:width="1dp"
        android:color="#337C4DFF" />
</shape>
