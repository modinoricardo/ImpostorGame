<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow -->
    <item>
        <shape>
            <corners android:radius="18dp"/>
            <solid android:color="#2200E5FF"/>
        </shape>
    </item>

    <!-- Button body -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape>
            <corners android:radius="16dp"/>
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00E5FF"
                android:endColor="#7C4DFF"/>
            <stroke android:width="1dp" android:color="#66FFFFFF"/>
        </shape>
    </item>

</layer-list>
