<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Glow exterior morado suave -->
    <item>
        <shape>
            <corners android:radius="22dp" />
            <solid android:color="#337C4DFF" />
        </shape>
    </item>

    <!-- Cuerpo del botón: azul oscuro con toque morado -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape>
            <corners android:radius="20dp" />

            <!-- Degradado azul oscuro -->
            <gradient
                android:angle="90"
                android:centerColor="#1E2F4A"
                android:endColor="#26385C"
                android:startColor="#152338"
                android:type="linear" />

            <!-- Borde morado claro -->
            <stroke
                android:width="1dp"
                android:color="#7C4DFF" />
        </shape>
    </item>

</layer-list>
