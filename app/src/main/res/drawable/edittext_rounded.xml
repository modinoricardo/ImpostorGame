<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo del EditText -->
    <solid android:color="@android:color/transparent"/>

    <!-- Borde redondeado -->
    <stroke
        android:width="2dp"
        android:color="#606060"/> <!-- color del borde -->

    <!-- Radio de esquinas (ajusta a tu gusto) -->
    <corners android:radius="24dp"/>

    <!-- Padding interno para que el texto no quede pegado -->
    <padding
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="12dp"/>
</shape>
