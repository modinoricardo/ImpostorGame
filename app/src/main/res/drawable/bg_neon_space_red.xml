<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#1A0B0B"
                android:centerColor="#33100F"
                android:endColor="#12070A"/>
        </shape>
    </item>
    <item android:top="-120dp" android:left="-120dp">
        <shape>
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#33FF1744"
                android:centerColor="#22FF4040"
                android:endColor="#00000000"/>
        </shape>
    </item>
</layer-list>