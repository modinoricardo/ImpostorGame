<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="22dp" />
            <solid android:color="#33FF1744" />
        </shape>
    </item>
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape>
            <corners android:radius="20dp" />
            <gradient
                android:angle="90"
                android:startColor="#3D0A0A"
                android:centerColor="#5C1010"
                android:endColor="#6B1515"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#FF1744" />
        </shape>
    </item>
</layer-list>