<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="22dp" />
            <solid android:color="#3300C853" />
        </shape>
    </item>
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape>
            <corners android:radius="20dp" />
            <gradient
                android:angle="90"
                android:startColor="#0D2B1F"
                android:centerColor="#163826"
                android:endColor="#1A4230"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#00C853" />
        </shape>
    </item>
</layer-list>